# Open WebUI Environment Variables (Railway Template)
# Copy to .env and set values before or after deployment.

# Database path, file for SQLite; use PostgreSQL URL for Postgres setup
DATABASE_URL=sqlite:////data/open_webui.db

# Port the app listens on (must match EXPOSE in Dockerfile)
PORT=8080

# Hostname shown in Open WebUI links (set after first deploy)
WEBSITE_HOSTNAME=https://my-app-production.up.railway.app

# Authentication settings (disabled by default; enable after initial admin setup)
ENABLE_SIGNUP=true
DISABLE_SIGNUP=false

# OAuth settings (optional, set after deployment)
ENABLE_OAUTH_SIGN_IN=false
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_ALLOW_EXISTING_USER_REGISTRATION=true
ENABLE_OAUTH_GROUP_MANAGEMENT=false
OAUTH_ROLE_MANAGEMENT=false
# Default LLM model overrides (optional, requires Ollama integration)
DEFAULT_MODELS=llama3.1:latest
PRIMARY_MODEL=llama3.1:latest
CHAT_DEFAULT_MODEL=llama3.1:latest
