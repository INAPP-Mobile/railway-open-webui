# =============================================================================
# Open WebUI — Railway Template (slim v3)
# =============================================================================
# Only the variables a user actually needs to set at first deploy are listed
# below. Everything else (sign-up gating, OAuth, RAG toggles, etc.) lives in
# the Open WebUI admin UI after the first login, so the deploy form stays short.
#
# Run `python3 scripts/set-service-vars.py <project-id> <env-id> .env.example`
# to push these to Railway, then re-generate and re-publish the template.
# =============================================================================

# --- Initial knobs (rendered in the Railway template deploy form) -------------

# Cryptographic key used to sign cookies/JWTs. Leave default to let Railway
# auto-generate a stable 32-char secret at deploy time. Do not edit unless you
# intentionally want to invalidate every active session.
WEBUI_SECRET_KEY=${{secret(32)}}

# Public URL of this Open WebUI deployment. Leave empty on first deploy, then
# set it to your Railway app URL (e.g. https://webui-production.up.railway.app)
# from the Variables tab once the service is live. Required for OAuth + CORS.
WEBSITE_HOSTNAME=

# Default models shown in the chat model picker (comma-separated, optional).
# Leave empty to let users pick after connecting Ollama / OpenAI / OpenRouter.
# Example: "llama3.1:latest,gpt-4o"
DEFAULT_MODELS=

# OpenAI API key. Optional — only needed if you connect to api.openai.com,
# OpenRouter (https://openrouter.ai), Groq, Together AI, or any
# OpenAI-compatible provider.
OPENAI_API_KEY=

# Base URL for the OpenAI-compatible provider above. Leave empty for
# https://api.openai.com/v1. Examples:
#   https://openrouter.ai/api/v1
#   https://api.groq.com/openai/v1
#   http://ollama.railway.internal:11434/v1
OPENAI_API_BASE_URL=

# =============================================================================
# Advanced settings (post-deploy)
# =============================================================================
# The variables below are NOT exposed in the template deploy form to keep the
# first-deploy experience short. If you need them, add them from the Railway
# Variables tab AFTER the service has deployed. Every single one of these is
# also configurable from the Open WebUI admin UI at /admin/settings.
#
# ENABLE_SIGNUP              — admin UI: Settings → General → Enable Sign-Up
# DISABLE_SIGNUP             — admin UI: Settings → General → Disable Sign-Up
# ENABLE_OAUTH_SIGN_IN       — admin UI: Settings → OAuth
# OAUTH_CLIENT_ID/SECRET     — admin UI: Settings → OAuth
# OAUTH_PROVIDER_NAME/URL    — admin UI: Settings → OAuth
# ENABLE_API_KEY_REQ         — admin UI: Settings → Authentication
# DEFAULT_USER_ROLE          — admin UI: Settings → Default User Role
# ENABLE_RAG_WEB_LOADER      — admin UI: Documents → Web Loader toggle
# RAG_EMBEDDING_MODEL        — admin UI: Documents → Embedding Model
# ENABLE_IMAGE_GENERATION    — admin UI: Images → Enable Image Generation
# ENABLE_WEB_SEARCH          — admin UI: Web Search → Enable Web Search
# WEBUI_AUTH_TRUSTED_EMAIL_HEADER — admin UI: Settings → Auth Trusted Header
#
# See the upstream Open WebUI .env.example for the canonical list of ~150 vars:
# https://github.com/open-webui/open-webui/blob/main/.env.example
